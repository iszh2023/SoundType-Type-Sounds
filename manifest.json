{
  "manifest_version": 3,
  "name": "SoundType",
  "version": "0.2.0",
  "description": "Pick a sound series (Roblox, Mario, etc.) and hear a random sound on each key press.",
  "permissions": ["storage", "activeTab", "scripting"],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "SoundType" },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["sounds/*/*", "icons/*", "assets/*"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  }
}
